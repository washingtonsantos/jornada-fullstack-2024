{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\logs\\fina\\log-fina-api.txt",
          "rollingInterval": "Day"
          //"formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "BackendURL": "http://localhost:5178",
  "FrontendURL": "http://localhost:5170",
  "ConnectionStrings": {
    "PostgresConnection": "User ID=postgres;Password=201608;Host=localhost;Port=5432;Database=fina-dev;"
  },
  "AllowedHosts": "*"
}
